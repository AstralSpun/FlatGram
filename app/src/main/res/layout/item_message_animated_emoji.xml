<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false"
    android:paddingStart="4dp"
    android:paddingTop="1dp"
    android:paddingEnd="6dp"
    android:paddingBottom="1dp">

    <TextView
        android:id="@+id/messageAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_message_avatar"
        android:gravity="center"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/animatedEmojiContent"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="A"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/animatedEmojiContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:clipToPadding="false"
        android:orientation="vertical"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@id/messageAvatar"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/messageSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="Alice" />

        <FrameLayout
            android:id="@+id/messageAnimatedEmojiFrame"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:background="@android:color/transparent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <org.flatgram.messenger.adapter.AnimatedEmojiPlayerView
                android:id="@+id/messageAnimatedEmojiPlayer"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/messageEmojiThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <TextView
                android:id="@+id/messageEmojiFallback"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="?attr/colorOnSurface"
                android:textSize="44sp"
                android:visibility="gone"
                tools:text="🙂"
                tools:visibility="visible" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/messageMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="-2dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/messageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="13:03" />

            <TextView
                android:id="@+id/messageSendState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"
                tools:text="..." />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
